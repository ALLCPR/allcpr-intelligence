# Copy to `.env` and fill in. Do not commit your real .env.

# Runtime identity
ENV=local
PORT=8001

# Google Maps Platform — optional and gated.
# Needed only for explicit live Places/geocoding enrichment commands.
# The dashboard and public-data national model load without this key.
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=

# US Census API — optional. ACS works without a key, but a key raises the
# per-IP rate limit. Get one free at https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# BLS — optional, currently stubbed.
BLS_API_KEY=

# AI executive summary — OPTIONAL. Rephrases the already-collected,
# deterministic report into a narrative. Never invents numbers; the pipeline
# runs fine without it. Choose a provider with LLM_PROVIDER below.
#
# Groq — FREE, OpenAI-compatible. Sign up + key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# OpenAI — paid. https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# "groq" | "openai" | "" (auto: prefers Groq when GROQ_API_KEY is set)
LLM_PROVIDER=

# Foursquare — optional. Enables Foursquare commercial-anchor source.
# Free tier ~1k calls/day at developer.foursquare.com.
FOURSQUARE_API_KEY=

# Drive-time isochrone catchments (optional). Two providers; ORS is tried
# first, then Mapbox. Either one enables --catchment-minutes.
#
# OpenRouteService — card-free. Email signup only at openrouteservice.org,
# 500 isochrone requests/day. Recommended starting point.
ORS_API_KEY=
OPENROUTE_API_KEY=
# Mapbox — 100k requests/month but requires a credit card to activate.
MAPBOX_TOKEN=

# Adzuna jobs API — optional. Augments the manual job_postings.csv with
# live healthcare-role postings, filtered to those mentioning BLS/CPR/AHA.
# Free tier 250 calls/month. Sign up at developer.adzuna.com.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us

# Yelp Fusion — optional. Cross-validates Google competitor pool against
# Yelp's cprclasses + firstaidclasses categories; augments matched
# competitors with Yelp rating / review count / categories. Free tier
# 500 calls/day at fusion.yelp.com.
YELP_API_KEY=

# Network behavior
REQUEST_TIMEOUT=20
RATE_LIMIT_SECONDS=1.0
MAX_RETRIES=4
RETRY_BACKOFF_SECONDS=2.0

# Sampling defaults
DEFAULT_RADIUS_MILES=5
GRID_SPACING_MILES=2.5
MAX_CANDIDATES_PER_CITY=12
METRO_DEDUPE_DISTANCE_MILES=1.0

# Place-detail enrichment
COMPETITOR_HYDRATE_TOP_N=5
DEMAND_TOP_N_PER_CATEGORY=5
ANCHOR_MAX_DISTANCE_MILES=0.75

# Competitor website analysis: homepage + at most one obvious classes/booking
# page, with conservative unknowns on failures.
COMPETITOR_WEBSITE_ANALYSIS_ENABLED=true
COMPETITOR_WEBSITE_TIMEOUT=5

# Photo URL safety. Saved reports still avoid API-key-bearing photo URLs; this
# flag is reserved for private tooling that explicitly calls the photo helper.
SAFE_PHOTO_URLS=true

# Profitability model (estimates only — never presented as fact)
AVG_CPR_COURSE_PRICE=85
AVG_BLS_COURSE_PRICE=95
AVG_STUDENTS_PER_CLASS=8
CLASSES_PER_WEEK_LOW=3
CLASSES_PER_WEEK_MID=6
CLASSES_PER_WEEK_HIGH=10

# Logging
LOG_LEVEL=INFO

# Cache + freshness layer
CACHE_ENABLED=true
CACHE_TTL_DEFAULT_DAYS=30
CACHE_TTL_NEARBY_SEARCH_DAYS=30
CACHE_TTL_TEXT_SEARCH_DAYS=14
CACHE_TTL_PLACE_DETAILS_DAYS=30
CACHE_TTL_CENSUS_DAYS=365
CACHE_TTL_BLS_QCEW_DAYS=365
